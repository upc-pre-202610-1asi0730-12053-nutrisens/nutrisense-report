@startuml NutriSense - Analytics & Reporting Database Diagram

skinparam linetype ortho
hide circle
hide methods

!define TABLE(name,desc) entity name as "desc" << (T, #AADDFF) >>
!define PK(x) <u>x</u>
!define FK(x) <i>x</i>

TABLE(user_analytics, "user_analytics") {
  PK(id) : INT AUTO_INCREMENT
  --
  FK(user_id) : INT NOT NULL
  current_streak : INT NOT NULL
  longest_streak : INT NOT NULL
  weekly_completion_rate : DECIMAL(5,4) NOT NULL
  last_adherence_score : DECIMAL(5,4)
  last_log_date : VARCHAR(10)
  last_progress_calculated_at : DATETIME
  created_at : DATETIME
  updated_at : DATETIME
}

TABLE(progress_snapshots, "progress_snapshots") {
  PK(id) : INT AUTO_INCREMENT
  --
  FK(user_analytics_id) : INT NOT NULL
  date : VARCHAR(10) NOT NULL
  total_calories : DECIMAL(10,2) NOT NULL
  total_protein_g : DECIMAL(10,2) NOT NULL
  total_carbs_g : DECIMAL(10,2) NOT NULL
  total_fat_g : DECIMAL(10,2) NOT NULL
  adherence_score : DECIMAL(5,4) NOT NULL
  is_complete : TINYINT(1) NOT NULL
  created_at : DATETIME NOT NULL
}

' Constraints
note right of user_analytics
  UNIQUE (user_id)
  [ix_user_analytics_records_user_id]
end note

note right of progress_snapshots
  INDEX (user_analytics_id, date)
  [ix_progress_snapshots_analytics_date]
end note

' Relationships
user_analytics ||--o{ progress_snapshots : "records\n(1 to 0..*)"

@enduml
