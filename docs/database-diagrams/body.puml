@startuml NutriSense - Body & Health Metrics Database Diagram

skinparam linetype ortho
hide circle
hide methods

!define TABLE(name,desc) entity name as "desc" << (T, #AADDFF) >>
!define PK(x) <u>x</u>
!define FK(x) <i>x</i>

TABLE(body_metrics, "body_metrics") {
  PK(id) : INT AUTO_INCREMENT
  --
  user_id : INT NOT NULL
  height_cm : DECIMAL(5,2) NOT NULL
  date_of_birth : LONGTEXT
  biological_sex : VARCHAR(25)
  activity_level : VARCHAR(25)
  bmi_value : DECIMAL(5,2)
  bmi_category : VARCHAR(20)
  bmr : DECIMAL(8,2)
  tdee : DECIMAL(8,2)
  macro_daily_calories : INT
  macro_protein_g : DECIMAL(6,1)
  macro_carbs_g : DECIMAL(6,1)
  macro_fat_g : DECIMAL(6,1)
  macro_fiber_g : DECIMAL(6,1)
  created_at : DATETIME
  updated_at : DATETIME
}

TABLE(body_measurements, "body_measurements") {
  PK(id) : INT AUTO_INCREMENT
  --
  FK(user_id) : INT NOT NULL
  neck_cm : DECIMAL(5,2) NOT NULL
  waist_cm : DECIMAL(5,2) NOT NULL
  measured_at : DATETIME NOT NULL
}

TABLE(user_goals, "user_goals") {
  PK(id) : INT AUTO_INCREMENT
  --
  FK(user_id) : INT NOT NULL
  goal : VARCHAR(20) NOT NULL
  start_weight_kg : DECIMAL(5,2) NOT NULL
  target_weight_kg : DECIMAL(5,2) NOT NULL
  weekly_rate_kg : DECIMAL(4,2) NOT NULL
  daily_calorie_target : INT NOT NULL
  caloric_adjustment : DECIMAL(8,2) NOT NULL
  protein_target_g : DECIMAL(6,1) NOT NULL
  carbs_target_g : DECIMAL(6,1) NOT NULL
  fat_target_g : DECIMAL(6,1) NOT NULL
  fiber_target_g : DECIMAL(6,1) NOT NULL
  active : TINYINT(1) NOT NULL
  set_at : DATETIME NOT NULL
}

TABLE(weight_logs, "weight_logs") {
  PK(id) : INT AUTO_INCREMENT
  --
  FK(user_id) : INT NOT NULL
  weight_kg : DECIMAL(5,2) NOT NULL
  note : VARCHAR(500)
  logged_at : DATETIME NOT NULL
}

' Constraints
note right of body_metrics
  ALTERNATE KEY (user_id)
  [a_k_body_metrics_user_id]
  child tables reference user_id
  as principal key
end note

note bottom of body_measurements
  INDEX (user_id)
end note

note bottom of user_goals
  INDEX (user_id)
end note

note bottom of weight_logs
  INDEX (user_id)
end note

' Relationships
body_metrics ||--o{ body_measurements : "tracks\n(1 to 0..*)"
body_metrics ||--o{ user_goals        : "sets\n(1 to 0..*)"
body_metrics ||--o{ weight_logs       : "records\n(1 to 0..*)"

@enduml
