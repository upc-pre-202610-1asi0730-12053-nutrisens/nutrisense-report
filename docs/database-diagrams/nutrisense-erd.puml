@startuml NutriSense ERD
skinparam monochrome false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam defaultFontSize 12

package "IAM" #E8F4FD {
  entity "iam_users" as users {
    * id : UUID <<PK>>
    --
    * email : VARCHAR(320) <<UNIQUE>>
    * password_hash : TEXT
    * first_name : VARCHAR(100)
    * last_name : VARCHAR(100)
    avatar_url : TEXT
    * role : VARCHAR(20)
    * created_at : TIMESTAMP WITH TIME ZONE
    * updated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of users
    role ∈ {free_user,
    premium_user, admin}
  end note
}

package "Nutrition Tracking" #FEF9E7 {
  entity "nutrition_food_items" as food_items {
    * id : UUID <<PK>>
    --
    * name : VARCHAR(255)
    brand : VARCHAR(255)
    * calories_per_100g : NUMERIC(8,2)
    * protein_per_100g : NUMERIC(8,2)
    * carbs_per_100g : NUMERIC(8,2)
    * fat_per_100g : NUMERIC(8,2)
    fiber_per_100g : NUMERIC(8,2)
    * source : VARCHAR(50)
    * created_at : TIMESTAMP WITH TIME ZONE
  }
  note right of food_items
    source ∈ {open_food_facts, usda}
  end note

  entity "nutrition_logs" as nutrition_logs {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>>
    * log_date : DATE
    * created_at : TIMESTAMP WITH TIME ZONE
    * updated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of nutrition_logs
    UNIQUE (user_id, log_date)
  end note

  entity "nutrition_food_entries" as food_entries {
    * id : UUID <<PK>>
    --
    * log_id : UUID <<FK>>
    * food_item_id : UUID <<FK>>
    * amount_grams : NUMERIC(8,2)
    * meal_type : VARCHAR(20)
    * logged_at : TIMESTAMP WITH TIME ZONE
  }
  note right of food_entries
    meal_type ∈ {breakfast,
    lunch, dinner, snack}
  end note
}

package "Body & Health Metrics" #EAFAF1 {
  entity "body_profiles" as body_profiles {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>> <<UNIQUE>>
    * weight_kg : NUMERIC(6,2)
    * height_cm : NUMERIC(5,2)
    * birth_date : DATE
    * biological_sex : VARCHAR(10)
    * activity_level : VARCHAR(30)
    * goal_type : VARCHAR(20)
    target_weight_kg : NUMERIC(6,2)
    * created_at : TIMESTAMP WITH TIME ZONE
    * updated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of body_profiles
    goal_type ∈ {lose_weight,
    gain_muscle, maintain}
  end note

  entity "body_weight_records" as weight_records {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>>
    * weight_kg : NUMERIC(6,2)
    * recorded_at : DATE
    note : TEXT
    * created_at : TIMESTAMP WITH TIME ZONE
  }
}

package "Smart Recommendations" #FDF2F8 {
  entity "recs_sets" as recs_sets {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>>
    * calorie_budget : NUMERIC(8,2)
    * protein_deficit : NUMERIC(8,2)
    * weather_condition : VARCHAR(20)
    * time_of_day : VARCHAR(15)
    * was_applied : BOOLEAN
    * generated_at : TIMESTAMP WITH TIME ZONE
    * expires_at : TIMESTAMP WITH TIME ZONE
  }
  note right of recs_sets
    weather ∈ {hot, cold,
    rainy, neutral}
    time_of_day ∈ {breakfast,
    lunch, dinner, snack}
  end note

  entity "recs_items" as recs_items {
    * id : UUID <<PK>>
    --
    * set_id : UUID <<FK>>
    * food_name : VARCHAR(255)
    * reason_code : VARCHAR(50)
    reason_description : VARCHAR(500)
    * match_score : NUMERIC(5,4)
    external_food_id : VARCHAR(100)
  }
}

package "Activity & Wearable Sync" #FEF5E7 {
  entity "activity_logs" as activity_logs {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>>
    * log_date : DATE
    * total_calories_burned : NUMERIC(8,2)
    * total_steps : INTEGER
    synced_at : TIMESTAMP WITH TIME ZONE
    * created_at : TIMESTAMP WITH TIME ZONE
    * updated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of activity_logs
    UNIQUE (user_id, log_date)
  end note

  entity "activity_records" as activity_records {
    * id : UUID <<PK>>
    --
    * log_id : UUID <<FK>>
    * activity_type : VARCHAR(30)
    * duration_minutes : INTEGER
    * calories_burned : NUMERIC(8,2)
    steps : INTEGER
    source_device : VARCHAR(100)
    * recorded_at : TIMESTAMP WITH TIME ZONE
  }
  note right of activity_records
    activity_type ∈ {walking,
    running, cycling,
    swimming, strength, other}
  end note

  entity "activity_wearable_tokens" as wearable_tokens {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>> <<UNIQUE>>
    * access_token : TEXT
    * refresh_token : TEXT
    * expires_at : TIMESTAMP WITH TIME ZONE
    * created_at : TIMESTAMP WITH TIME ZONE
  }
}

package "Analytics & Reporting" #F4ECF7 {
  entity "analytics_progress_reports" as reports {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>>
    * period_start : DATE
    * period_end : DATE
    * period_type : VARCHAR(10)
    avg_daily_calories : NUMERIC(8,2)
    avg_protein_g : NUMERIC(8,2)
    avg_carbs_g : NUMERIC(8,2)
    avg_fat_g : NUMERIC(8,2)
    total_calories_burned : NUMERIC(10,2)
    weight_change_kg : NUMERIC(6,2)
    adherence_percent : NUMERIC(5,2)
    days_logged : INTEGER
    * generated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of reports
    period_type ∈ {weekly,
    monthly, custom}
  end note

  entity "analytics_weight_snapshots" as weight_snapshots {
    * id : UUID <<PK>>
    --
    * report_id : UUID <<FK>>
    * snapshot_date : DATE
    * weight_kg : NUMERIC(6,2)
  }
}

package "Subscriptions & Billing" #FDEDEC {
  entity "billing_subscriptions" as subscriptions {
    * id : UUID <<PK>>
    --
    * user_id : UUID <<FK>> <<UNIQUE>>
    * plan_type : VARCHAR(30)
    * status : VARCHAR(20)
    stripe_customer_id : TEXT
    stripe_subscription_id : TEXT
    * current_period_start : DATE
    * current_period_end : DATE
    canceled_at : TIMESTAMP WITH TIME ZONE
    * created_at : TIMESTAMP WITH TIME ZONE
    * updated_at : TIMESTAMP WITH TIME ZONE
  }
  note right of subscriptions
    plan_type ∈ {free,
    premium, premium_annual}
    status ∈ {active, cancelled,
    past_due, trialing}
  end note

  entity "billing_invoices" as invoices {
    * id : UUID <<PK>>
    --
    * subscription_id : UUID <<FK>>
    * user_id : UUID <<FK>>
    * amount : NUMERIC(10,2)
    * currency : VARCHAR(3)
    * status : VARCHAR(20)
    stripe_invoice_id : TEXT
    * created_at : TIMESTAMP WITH TIME ZONE
    paid_at : TIMESTAMP WITH TIME ZONE
  }
}

users ||--o{ nutrition_logs          : "has"
users ||--o| body_profiles           : "has"
users ||--o{ weight_records          : "logs"
users ||--o{ recs_sets               : "receives"
users ||--o{ activity_logs           : "has"
users ||--o| wearable_tokens         : "connects"
users ||--o{ reports                 : "generates"
users ||--o| subscriptions           : "holds"
users ||--o{ invoices                : "billed via"

nutrition_logs  ||--o{ food_entries      : "contains"
food_items      ||--o{ food_entries      : "referenced by"

recs_sets       ||--o{ recs_items        : "contains"

activity_logs   ||--o{ activity_records  : "contains"

reports         ||--o{ weight_snapshots  : "contains"

subscriptions   ||--o{ invoices          : "generates"

@enduml