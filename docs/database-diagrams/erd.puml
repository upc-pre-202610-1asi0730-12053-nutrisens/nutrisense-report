}
note right of CLog : BC-02 · Nutrition Tracking\nUNIQUE (user_id, log_date)

entity "food_entries" as FEnt {
  * id : UUID <<PK>>
  --
  * consumption_log_id : UUID <<FK>>
  * external_food_id : VARCHAR(100)
  * external_food_source : VARCHAR(20)
