@startuml NutriSense - Subscriptions & Billing Database Diagram

skinparam linetype ortho
hide circle
hide methods

!define TABLE(name,desc) entity name as "desc" << (T, #AADDFF) >>
!define PK(x) <u>x</u>
!define FK(x) <i>x</i>

TABLE(subscription_plans, "subscription_plans") {
  PK(id) : UUID NOT NULL
  --
  tier : VARCHAR(10) NOT NULL
    CHECK (tier IN ('BASIC','PRO','PREMIUM'))
  billing_cycle : VARCHAR(10) NOT NULL
    CHECK (billing_cycle IN ('MONTHLY','ANNUAL'))
  price_amount : NUMERIC(10,2) NOT NULL CHECK (price_amount >= 0)
  price_currency : VARCHAR(3) NOT NULL DEFAULT 'USD'
  max_meal_scans : INT NOT NULL DEFAULT 0
  has_advanced_analytics : BOOLEAN NOT NULL DEFAULT FALSE
  stripe_price_id : VARCHAR(100) NOT NULL
  is_active : BOOLEAN NOT NULL DEFAULT TRUE
  created_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
}

TABLE(subscription_aggregates, "subscription_aggregates") {
  PK(id) : UUID NOT NULL
  --
  FK(user_id) : UUID NOT NULL
  created_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
  updated_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
}

TABLE(subscriptions, "subscriptions") {
  PK(id) : UUID NOT NULL
  --
  FK(subscription_aggregate_id) : UUID NOT NULL
  FK(plan_id) : UUID NOT NULL
  status : VARCHAR(15) NOT NULL
    CHECK (status IN ('ACTIVE','CANCELLED','EXPIRED','PAST_DUE'))
  start_date : DATE NOT NULL
  end_date : DATE NOT NULL
  stripe_subscription_id : VARCHAR(100) NOT NULL
  stripe_customer_id : VARCHAR(100) NOT NULL
  cancelled_at : TIMESTAMPTZ
  created_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
  updated_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
}

TABLE(payments, "payments") {
  PK(id) : UUID NOT NULL
  --
  FK(subscription_aggregate_id) : UUID NOT NULL
  FK(subscription_id) : UUID NOT NULL
  amount : NUMERIC(10,2) NOT NULL CHECK (amount > 0)
  currency : VARCHAR(3) NOT NULL DEFAULT 'USD'
  status : VARCHAR(15) NOT NULL
    CHECK (status IN ('PENDING','SUCCEEDED','FAILED'))
  stripe_payment_intent_id : VARCHAR(100) NOT NULL
  paid_at : TIMESTAMPTZ
  created_at : TIMESTAMPTZ NOT NULL DEFAULT NOW()
}

' Constraints
note right of subscription_plans
  UNIQUE (tier, billing_cycle)
  UNIQUE (stripe_price_id)
  INDEX (tier, is_active)
end note

note right of subscription_aggregates
  UNIQUE (user_id)
end note

note right of subscriptions
  INDEX (subscription_aggregate_id, status)
  INDEX (stripe_subscription_id)
  CHECK (end_date >= start_date)
  ' One ACTIVE subscription per aggregate enforced at app level
end note

note right of payments
  UNIQUE (stripe_payment_intent_id)
  INDEX (subscription_aggregate_id, status)
  INDEX (subscription_id)
end note

' Relationships
subscription_plans ||--o{ subscriptions : "defines terms for\n(1 to 0..*)"
subscription_aggregates ||--o{ subscriptions : "holds\n(1 to 0..*)"
subscription_aggregates ||--o{ payments : "records\n(1 to 0..*)"
subscriptions ||--o{ payments : "generates\n(1 to 0..*)"

@enduml