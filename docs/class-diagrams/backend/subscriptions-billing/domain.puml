@startuml NutriSense - Subscriptions - Domain

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "Nutrisense.Platform.Subscriptions" {

  package "Shared [stubs]" {
    interface IBaseRepository<TEntity> {
      +AddAsync(entity: TEntity): Task
      +FindByIdAsync(id: int): Task<TEntity?>
      +Update(entity: TEntity): void
      +Remove(entity: TEntity): void
      +ListAsync(): Task<IEnumerable<TEntity>>
    }

    interface IAuditableEntity {
      +CreatedAt: DateTimeOffset?
      +UpdatedAt: DateTimeOffset?
    }

    abstract class DomainEventBase {
      +EventId: Guid
      +OccurredAt: DateTimeOffset
    }
  }

  package "Domain" {

    package "Model.Aggregates" {
      class UserSubscription {
        +Id: int
        +UserId: int
        +PlanId: int
        +PlanKey: string
        +Status: string
        +BillingPeriod: string
        +PeriodStart: DateTimeOffset
        +PeriodEnd: DateTimeOffset
        +CancelAtPeriodEnd: bool
        +StripeSubscriptionId: string?
        +LastPlanChangeAt: DateTimeOffset?
        +PaymentMethodId: int?
        -_paymentRecords: List<PaymentRecord>
        +PaymentRecords: IReadOnlyCollection<PaymentRecord>
        +CreatedAt: DateTimeOffset?
        +UpdatedAt: DateTimeOffset?
        +ApplyPayment(record: PaymentRecord): void
        +ApplyActivation(): void
        +ApplyCancel(cancelAtPeriodEnd: bool): void
        +ApplyRenewal(record: PaymentRecord, newPeriodEnd: DateTimeOffset): void
        +ApplyPlanChangeWithPayment(...): void
        +ApplyPlanChangeWithoutPayment(...): void
      }

      class SubscriptionPlan {
        +Id: int
        +Key: string
        +PriceMonthly: decimal
        +PriceAnnual: decimal?
        +Features: List<string>
        +Currency: string
        +GetEffectivePrice(billingPeriod: string): decimal
      }

      class PaymentMethod {
        +Id: int
        +UserId: int
        +LastFour: string
        +Brand: string
        +ExpiryMonth: int
        +ExpiryYear: int
        +CardholderName: string
        +StripePaymentMethodId: string
        +CreatedAt: DateTimeOffset?
        +UpdatedAt: DateTimeOffset?
      }
    }

    package "Model.Entities" {
      class PaymentRecord {
        +Id: int
        +UserSubscriptionId: int
        +Amount: decimal
        +Currency: string
        +Status: string
        +ProcessedAt: DateTimeOffset
        +StripePaymentIntentId: string?
      }
    }

    package "Model.ValueObjects" {
      class Money <<record>> {
        +Amount: decimal
        +Currency: string
      }
      class BillingPeriod <<record>> {
        +{static} Monthly: string
        +{static} Annual: string
        +Value: string
      }
      class SubscriptionStatus <<record>> {
        +Value: string
      }
      class PlanKey <<record>> {
        +Value: string
      }
      class CardBrand <<record>> {
        +Value: string
      }
      class CardExpiry <<record>> {
        +Month: int
        +Year: int
      }
    }

    package "Model.Commands" {
      class SelectSubscriptionPlanCommand <<record>> {
        +UserId: int
        +PlanKey: string
        +PaymentMethodId: int
        +BillingPeriod: string
      }
      class ChangeSubscriptionPlanCommand <<record>> {
        +UserSubscriptionId: int
        +NewPlanKey: string
        +BillingPeriod: string
        +PaymentMethodId: int?
      }
      class CancelSubscriptionCommand <<record>> {
        +UserSubscriptionId: int
        +CancelAtPeriodEnd: bool
      }
      class RenewSubscriptionCommand <<record>> {
        +UserSubscriptionId: int
      }
      class ActivateSubscriptionCommand <<record>> {
        +UserSubscriptionId: int
      }
      class SubmitPaymentCommand <<record>> {
        +UserSubscriptionId: int
      }
      class EnablePlanFeaturesCommand <<record>> {
        +UserSubscriptionId: int
      }
      class DisablePlanFeaturesCommand <<record>> {
        +UserSubscriptionId: int
      }
      class RegisterPaymentMethodCommand <<record>> {
        +UserId: int
        +LastFour: string
        +Brand: string
        +ExpiryMonth: int
        +ExpiryYear: int
        +CardholderName: string
        +StripePaymentMethodId: string
      }
    }

    package "Model.Queries" {
      class GetUserSubscriptionByUserIdQuery <<record>> {
        +UserId: int
      }
      class GetAllSubscriptionPlansQuery <<record>>
      class GetSubscriptionPlanByKeyQuery <<record>> {
        +Key: string
      }
      class GetPaymentMethodsByUserIdQuery <<record>> {
        +UserId: int
      }
      class GetPaymentHistoryBySubscriptionIdQuery <<record>> {
        +SubscriptionId: int
      }
    }

    package "Model.Events" {
      class PlanSelected <<record>>
      class PaymentSuccessful <<record>>
      class SubscriptionActivated <<record>>
      class SubscriptionCancelled <<record>>
      class SubscriptionRenewed <<record>>
      class PlanChanged <<record>>
      class BenefitsEnabled <<record>>
      class BenefitsDisabled <<record>>
    }

    package "Repositories" {
      interface IUserSubscriptionRepository {
        +FindByUserIdAsync(userId: int): Task<UserSubscription?>
        +FindActiveByUserIdAsync(userId: int): Task<UserSubscription?>
      }
      interface ISubscriptionPlanRepository {
        +FindByKeyAsync(key: string): Task<SubscriptionPlan?>
      }
      interface IPaymentMethodRepository {
        +FindByUserIdAsync(userId: int): Task<IEnumerable<PaymentMethod>>
      }
    }

    package "Services" {
      interface IPaymentGateway {
        +ChargeAsync(stripeCustomerId: string, stripePaymentMethodId: string, amount: Money): Task<PaymentResult>
      }
      class PaymentResult <<record>> {
        +Success: bool
        +StripePaymentIntentId: string?
        +FailureReason: string?
      }
    }
  }
}

' --- Aggregate / entity composition ---
UserSubscription "1" *--> "0..*" PaymentRecord : owns

' --- Auditing ---
IAuditableEntity <|.. UserSubscription
IAuditableEntity <|.. PaymentMethod

' --- Value objects ---
UserSubscription ..> BillingPeriod : validates
UserSubscription ..> SubscriptionStatus : validates
SubscriptionPlan ..> PlanKey : keyed by
SubscriptionPlan ..> Money : prices in
PaymentMethod ..> CardBrand : validates
PaymentMethod ..> CardExpiry : validates

' --- Command -> aggregate construction ---
SelectSubscriptionPlanCommand ..> UserSubscription : builds
RegisterPaymentMethodCommand ..> PaymentMethod : builds
ChangeSubscriptionPlanCommand ..> UserSubscription : targets
CancelSubscriptionCommand ..> UserSubscription : targets
RenewSubscriptionCommand ..> UserSubscription : targets
ActivateSubscriptionCommand ..> UserSubscription : targets
SubmitPaymentCommand ..> UserSubscription : targets
EnablePlanFeaturesCommand ..> UserSubscription : targets
DisablePlanFeaturesCommand ..> UserSubscription : targets

' --- Query -> read model ---
GetUserSubscriptionByUserIdQuery ..> UserSubscription : returns
GetAllSubscriptionPlansQuery ..> SubscriptionPlan : returns
GetSubscriptionPlanByKeyQuery ..> SubscriptionPlan : returns
GetPaymentMethodsByUserIdQuery ..> PaymentMethod : returns
GetPaymentHistoryBySubscriptionIdQuery ..> PaymentRecord : returns

' --- Events ---
DomainEventBase <|-- PlanSelected
DomainEventBase <|-- PaymentSuccessful
DomainEventBase <|-- SubscriptionActivated
DomainEventBase <|-- SubscriptionCancelled
DomainEventBase <|-- SubscriptionRenewed
DomainEventBase <|-- PlanChanged
DomainEventBase <|-- BenefitsEnabled
DomainEventBase <|-- BenefitsDisabled

' --- Repositories ---
IBaseRepository <|-- IUserSubscriptionRepository
IBaseRepository <|-- ISubscriptionPlanRepository
IBaseRepository <|-- IPaymentMethodRepository
IUserSubscriptionRepository ..> UserSubscription : aggregates
ISubscriptionPlanRepository ..> SubscriptionPlan : aggregates
IPaymentMethodRepository ..> PaymentMethod : aggregates

' --- Domain services ---
IPaymentGateway ..> Money : charges
IPaymentGateway ..> PaymentResult : returns

@enduml
