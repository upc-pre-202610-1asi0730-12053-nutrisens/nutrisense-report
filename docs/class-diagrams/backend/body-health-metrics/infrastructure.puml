@startuml NutriSense - Body & Health Metrics - Infrastructure

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "Nutrisense.BodyHealthMetrics.Infrastructure" {

  package "Calculators" {
    class MifflinStJeorBodyMetricsCalculator {
      +CalculateBmi(weightKg: decimal, heightCm: decimal): BmiResult
      +CalculateBmr(weightKg, heightCm, dateOfBirth, biologicalSex): decimal
      +CalculateTdee(bmr: decimal, activityLevel: string): decimal
      +CalculateCaloricAdjustment(goal: string, weeklyRateKg: decimal): decimal
      +CalculateDailyCaloricGoal(tdee: decimal, goal: string, weeklyRateKg: decimal): MacroTargets
    }
  }

  package "Persistence.EFC.Repositories" {
    class BodyMetricsRepository {
      -WithRelations(): IQueryable<BodyMetrics>
      +FindByUserIdAsync(userId: int, ct): Task<BodyMetrics?>
      +FindActiveGoalByUserIdAsync(userId: int, ct): Task<UserGoal?>
      +FindWeightHistoryByUserIdAsync(userId, from, to, ct): Task<IEnumerable<WeightLog>>
    }
  }

  package "Persistence.EFC.Configuration" {
    class BodyMetricsEntityTypeConfiguration {
      +Configure(builder: EntityTypeBuilder<BodyMetrics>): void
    }
    class WeightLogEntityTypeConfiguration {
      +Configure(builder: EntityTypeBuilder<WeightLog>): void
    }
    class BodyMeasurementEntityTypeConfiguration {
      +Configure(builder: EntityTypeBuilder<BodyMeasurement>): void
    }
    class UserGoalEntityTypeConfiguration {
      +Configure(builder: EntityTypeBuilder<UserGoal>): void
    }
  }
}

package "Domain [stubs]" {
  class BodyMetrics
  class WeightLog
  class BodyMeasurement
  class UserGoal
  interface IBodyMetricsRepository
  interface IBodyMetricsCalculator
}

package "Shared [stubs]" {
  abstract class "BaseRepository<T>" as BaseRepository
  class AppDbContext
  interface "IEntityTypeConfiguration<T>" as IEntityTypeConfiguration
}

' --- Calculator ---
MifflinStJeorBodyMetricsCalculator ..|> IBodyMetricsCalculator

' --- Repository ---
BodyMetricsRepository --|> BaseRepository
BodyMetricsRepository ..|> IBodyMetricsRepository
BodyMetricsRepository --> AppDbContext
BodyMetricsRepository ..> BodyMetrics
BodyMetricsRepository ..> WeightLog
BodyMetricsRepository ..> UserGoal

' --- EF Core configurations ---
BodyMetricsEntityTypeConfiguration ..|> IEntityTypeConfiguration
WeightLogEntityTypeConfiguration ..|> IEntityTypeConfiguration
BodyMeasurementEntityTypeConfiguration ..|> IEntityTypeConfiguration
UserGoalEntityTypeConfiguration ..|> IEntityTypeConfiguration

BodyMetricsEntityTypeConfiguration ..> BodyMetrics
WeightLogEntityTypeConfiguration ..> WeightLog
BodyMeasurementEntityTypeConfiguration ..> BodyMeasurement
UserGoalEntityTypeConfiguration ..> UserGoal

@enduml
