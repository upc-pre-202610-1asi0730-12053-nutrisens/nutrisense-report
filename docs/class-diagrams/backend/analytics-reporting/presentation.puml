@startuml NutriSense - Analytics & Reporting - Presentation

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "NutriSense.AnalyticsReporting" {

  package "Application [stubs]" {
    interface IAnalyticsCommandService
    interface IAnalyticsQueryService
  }

  package "Interfaces.REST" {
    class AnalyticsController {
      -analyticsCommandService: IAnalyticsCommandService
      -analyticsQueryService: IAnalyticsQueryService
      +GetProgressReport(userId: Guid, type: String): IActionResult
      +PostGenerateReport(request: GenerateReportRequest): IActionResult
      +GetStreaks(userId: Guid): IActionResult
      +GetDailyBalances(userId: Guid, from: String, to: String): IActionResult
    }

    class GenerateReportRequest {
      +UserId: Guid
      +ReportType: String
      +PeriodStart: DateOnly
      +PeriodEnd: DateOnly
    }

    class ProgressReportResponse {
      +Id: Guid
      +PeriodStart: DateOnly
      +PeriodEnd: DateOnly
      +AverageCalories: Decimal
      +WeightDeltaKg: Decimal
      +GoalAchievementPercent: Decimal
      +ReportType: String
    }

    class AnalyticsAssembler {
      +{static} ToProgressReportResponse(aggregate: AnalyticsAggregate): ProgressReportResponse
      +{static} ToStreakResponse(streak: Streak): StreakResponse
    }
  }
}

AnalyticsController --> IAnalyticsCommandService : uses
AnalyticsController --> IAnalyticsQueryService : uses
AnalyticsController --> AnalyticsAssembler : uses

@enduml
