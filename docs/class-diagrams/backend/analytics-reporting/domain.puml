@startuml NutriSense - Analytics & Reporting - Domain

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "NutriSense.AnalyticsReporting" {

  package "Domain" {

    package "Model.Aggregates" {
      class UserAnalytics <<aggregate root>> {
        +Id: int
        +UserId: int
        +CurrentStreak: int
        +LongestStreak: int
        +LastLogDate: DateOnly?
        +WeeklyCompletionRate: decimal
        +LastAdherenceScore: decimal?
        +LastProgressCalculatedAt: DateTimeOffset?
        +ProgressSnapshots: IReadOnlyCollection<ProgressSnapshot>
        +CreatedAt: DateTimeOffset?
        +UpdatedAt: DateTimeOffset?
        +UpdateStreak(today: DateOnly): void
        +UpdateAdherence(score: decimal): void
        +AddProgressSnapshot(snapshot: ProgressSnapshot): void
        +UpdateWeeklyCompletionRate(rate: decimal): void
      }
    }

    package "Model.Entities" {
      class ProgressSnapshot <<entity>> {
        +Id: int
        +UserAnalyticsId: int
        +Date: DateOnly
        +TotalCalories: decimal
        +TotalProteinG: decimal
        +TotalCarbsG: decimal
        +TotalFatG: decimal
        +AdherenceScore: decimal
        +IsComplete: bool
        +CreatedAt: DateTimeOffset
      }
    }

    package "Model.ValueObjects" {
      class AdherenceScore <<value object>> {
        +Value: decimal
      }

      class DateRange <<value object>> {
        +From: DateOnly
        +To: DateOnly
      }
    }

    package "Model.Commands" {
      class CalculateProgressCommand <<record>> {
        +UserId: int
      }
      class ExportReportPdfCommand <<record>> {
        +UserId: int
        +From: DateOnly
        +To: DateOnly
      }
      class GenerateProgressInsightsCommand <<record>> {
        +UserId: int
        +Date: DateOnly?
      }
      class GenerateVisualizationCommand <<record>> {
        +UserId: int
      }
      class UpdateUsageStreakCommand <<record>> {
        +UserId: int
      }
      class ViewDashboardCommand <<record>> {
        +UserId: int
      }
    }

    package "Model.Queries" {
      class GetDashboardQuery <<record>> {
        +UserId: int
        +Date: DateOnly
      }
      class GetProgressChartQuery <<record>> {
        +UserId: int
        +From: DateOnly
        +To: DateOnly
      }
      class GetStreakQuery <<record>> {
        +UserId: int
      }
    }

    package "Model.Events" {
      class DashboardViewed <<domain event>> {
        +UserId: int
      }
      class ProgressCalculated <<domain event>> {
        +UserId: int
        +AdherenceScore: decimal
      }
      class ReportExported <<domain event>> {
        +UserId: int
        +FileName: string
      }
      class UsageStreakUpdated <<domain event>> {
        +UserId: int
        +CurrentStreak: int
      }
      class UserDataAggregated <<domain event>> {
        +UserId: int
        +Date: DateOnly
      }
      class VisualizationGenerated <<domain event>> {
        +UserId: int
      }
    }

    package "Repositories" {
      interface IUserAnalyticsRepository {
        +FindByUserIdAsync(userId: int, ct): Task<UserAnalytics?>
        +FindOrCreateAsync(userId: int, ct): Task<UserAnalytics>
        +GetProgressSnapshotsAsync(userId: int, from: DateOnly, to: DateOnly, ct): Task<IEnumerable<ProgressSnapshot>>
      }
    }

    package "Services" {
      interface IAdherenceCalculator {
        +Calculate(actual: DailyMacroSummaryItem?, goal: UserGoalSummaryItem?): decimal
      }
      interface IReportPdfGenerator {
        +GenerateAsync(userId: int, range: DateRange, ct): Task<byte[]>
      }
      interface IStreakCalculator {
        +Calculate(lastLogDate: DateOnly?, currentStreak: int, longestStreak: int, today: DateOnly): (int, int)
      }
    }
  }

  package "Shared.Domain [stubs]" {
    interface IAuditableEntity
    abstract class DomainEventBase
    interface IBaseRepository<T>
  }
}

' Aggregate composition
UserAnalytics *--> "0..*" ProgressSnapshot : owns

' Shared building blocks
UserAnalytics ..|> IAuditableEntity
DashboardViewed --|> DomainEventBase
ProgressCalculated --|> DomainEventBase
ReportExported --|> DomainEventBase
UsageStreakUpdated --|> DomainEventBase
UserDataAggregated --|> DomainEventBase
VisualizationGenerated --|> DomainEventBase

' Repository contract
IUserAnalyticsRepository --|> IBaseRepository
IUserAnalyticsRepository ..> UserAnalytics : manages
IUserAnalyticsRepository ..> ProgressSnapshot : reads

' Domain services
IAdherenceCalculator ..> AdherenceScore : produces
IReportPdfGenerator ..> DateRange : covers
IStreakCalculator ..> UserAnalytics : computes for

' Commands raise events
CalculateProgressCommand ..> ProgressCalculated : triggers
GenerateProgressInsightsCommand ..> ProgressCalculated : triggers
GenerateProgressInsightsCommand ..> UserDataAggregated : triggers
GenerateProgressInsightsCommand ..> VisualizationGenerated : triggers
GenerateVisualizationCommand ..> VisualizationGenerated : triggers
UpdateUsageStreakCommand ..> UsageStreakUpdated : triggers
ViewDashboardCommand ..> DashboardViewed : triggers
ExportReportPdfCommand ..> ReportExported : triggers

' Queries read the aggregate
GetDashboardQuery ..> UserAnalytics : reads
GetProgressChartQuery ..> ProgressSnapshot : reads
GetStreakQuery ..> UserAnalytics : reads

@enduml
