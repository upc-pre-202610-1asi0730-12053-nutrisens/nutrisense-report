@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "analytics-reporting/application [stub]" {
  class useAnalyticsReportingStore <<store>>
}

package "analytics-reporting/presentation/routes" {
  class AnalyticsReportingRoutes <<router>>
}

package "analytics-reporting/presentation/views" {
  class AnalyticsView <<view>>
  class DashboardView <<view>>
}

package "analytics-reporting/presentation/components" {
  class KpiCardComponent <<component>>
  class MacroDonutChartComponent <<component>>
}

AnalyticsReportingRoutes ..> AnalyticsView : navigates to >
AnalyticsReportingRoutes ..> DashboardView : navigates to >

DashboardView ..> KpiCardComponent : contains >
DashboardView ..> MacroDonutChartComponent : contains >
AnalyticsView ..> KpiCardComponent : contains >
AnalyticsView ..> MacroDonutChartComponent : contains >

DashboardView o--> useAnalyticsReportingStore : uses >
AnalyticsView o--> useAnalyticsReportingStore : uses >
KpiCardComponent o--> useAnalyticsReportingStore : uses >

@enduml
