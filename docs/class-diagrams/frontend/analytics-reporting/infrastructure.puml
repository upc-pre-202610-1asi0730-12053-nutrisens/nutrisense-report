@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "analytics-reporting/domain/model [stub]" {
  class StreakRecord <<entity>>
}

package "shared/infrastructure [stub]" {
  class BaseApi <<api>>
}

package "external [stubs]" {
  class jsPDF <<library>>
  class autoTable <<library>>
}

package "analytics-reporting/infrastructure" {

  class AnalyticsReportingApi <<api>> {
    + getStreak(userId): Promise
    + getDashboard(userId, date): Promise
    + getProgress(userId, from, to): Promise
  }

  class StreakRecordAssembler <<assembler>> {
    + {static} toEntityFromResource(resource): StreakRecord|null
    + {static} toEntitiesFromResponse(response): StreakRecord[]
    + {static} toEntityFromResponse(response): StreakRecord|null
  }

  class PdfExportService <<service>> {
    + generateAnalyticsPdf(params): void
  }
}

AnalyticsReportingApi --|> BaseApi
StreakRecordAssembler ..> StreakRecord : creates >
PdfExportService ..> jsPDF : uses >
PdfExportService ..> autoTable : uses >

@enduml
