@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "analytics-reporting/domain/model" {

  class StreakRecord <<entity>> {
    + currentStreak: number
    + longestStreak: number
    + lastLogDate: string|null
    + weeklyCompletionRate: number
    + weeklyCompletionDays: boolean[]
    --
    + isBroken(): boolean
    + isAtRisk(): boolean
    + isActiveToday(): boolean
    + motivationalMessageKey(): string
    + weeklyCompletionPercent(): number
  }
}

package "analytics-reporting/domain/services" {

  class StreakCalculatorService <<domain service>> {
    + calculateStreak(logEntries, calorieGoal, proteinGoal): StreakRecord
  }

  class AdherenceCalculatorService <<domain service>> {
    + calculateAdherenceRate(logDates, days): number
    + weeklyAdherenceRate(logDates): number
    + monthlyAdherenceRate(logDates): number
  }
}

StreakCalculatorService ..> StreakRecord : creates >
AdherenceCalculatorService ..> StreakRecord : computes adherence for >

@enduml
