@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "subscriptions-billing/domain/model" {

  class PaymentMethod <<entity>> {
    + id: string
    + userId: string
    + lastFour: string
    + brand: CardBrand
    + expiryMonth: number
    + expiryYear: number
    + cardholderName: string
    + createdAt: string
    --
    + maskedNumber(): string
    + expiryLabel(): string
    + {static} detectBrand(cardNumber): CardBrand
  }

  class SubscriptionPlan <<entity>> {
    + id: number
    + key: string
    + priceMonthly: number
    + priceAnnual: number|null
    + currency: string
    + features: string[]
    --
    + hasFeature(feature): boolean
    + isFree(): boolean
    + isUpgradeFrom(lowerPlan): boolean
    + planChangeType(fromPlan): 'upgrade'|'downgrade'
    + featuresGainedOver(lowerPlan): string[]
  }

  class UserSubscription <<entity>> {
    + id: number
    + userId: number
    + planId: number
    + planKey: string
    + status: SubscriptionStatus
    + billingPeriod: BillingPeriod
    + periodStart: string|null
    + periodEnd: string|null
    + cancelAtPeriodEnd: boolean
    + stripeSubscriptionId: string|null
    + lastPlanChangeAt: string|null
    + paymentMethodId: number|null
    --
    + isActive(): boolean
    + willCancel(): boolean
    + renewalDate(): Date|null
    + daysUntilRenewal(now?): number|null
    + isFree(): boolean
    + canChangePlanToday(now?): boolean
    + proratedChangeAmount(fromPlan, toPlan, now?): number
  }

  class PaymentRecord <<entity>> {
    + id: number
    + userSubscriptionId: number
    + amount: number
    + amountUsd: number
    + currency: string
    + status: string
    + processedAt: string|null
    + paidAt: string|null
    + stripePaymentIntentId: string|null
    + type: string
    --
    + isPaid(): boolean
    + isFailed(): boolean
    + isRefunded(): boolean
    + isPending(): boolean
    + formattedAmount(): string
    + isPlanChange(): boolean
  }

  class BillingPeriod <<value object>> {
    + value: BillingPeriodValue
    --
    + isFree(): boolean
    + isMonthly(): boolean
    + isAnnual(): boolean
    + annualSavingsPercent(): number|null
  }

  class SubscriptionStatus <<value object>> {
    + value: SubscriptionStatusValue
    --
    + isActive(): boolean
    + isCancelled(): boolean
    + requiresAttention(): boolean
    + isPendingPayment(): boolean
    + isExpired(): boolean
  }

  class PlanTier <<value object>> {
    + value: PlanTierValue
    --
    + isAtLeast(minimum): boolean
    + historyLimitDays(): number
    + isFree(): boolean
  }

  class PlanFeature <<value object>> {
    + {static} ALL_FEATURES: PlanFeatureValue[]
    + value: PlanFeatureValue
  }
}

UserSubscription *--> SubscriptionStatus : status >
UserSubscription *--> BillingPeriod : billingPeriod >
UserSubscription --> SubscriptionPlan : subscribes to >
UserSubscription --> PaymentMethod : paid with >
SubscriptionPlan --> PlanTier : tier >
SubscriptionPlan --> PlanFeature : features >
PaymentRecord --> UserSubscription : billed for >

@enduml
