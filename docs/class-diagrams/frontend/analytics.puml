@startuml NutriSense - Analytics & Reporting Frontend Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "analytics" {

  package "domain.model" {
    class ProgressReport {
      +id: String
      +userId: String
      +periodStart: String
      +periodEnd: String
      +averageCalories: Number
      +weightDelta: Number
      +goalAchievementPercent: Number
      +reportType: ReportType
    }

    class Streak {
      +id: String
      +userId: String
      +streakType: StreakType
      +currentCount: Number
      +longestCount: Number
      +lastUpdated: String
      +isActive(): Boolean
    }

    class DailyBalance {
      +date: String
      +caloriesConsumed: Number
      +caloriesBurned: Number
      +netCalories: Number
      +goalMet: Boolean
    }

    enum ReportType {
      WEEKLY
      MONTHLY
      CUSTOM
    }

    enum StreakType {
      LOGGING_STREAK
      GOAL_STREAK
      ACTIVITY_STREAK
    }
  }

  package "application" {
    class AnalyticsStore {
      -progressReport: ProgressReport
      -streaks: Streak[]
      -dailyBalances: DailyBalance[]
      -loading: Boolean
      +fetchProgressReport(userId: String, type: ReportType): Promise<void>
      +fetchStreaks(userId: String): Promise<void>
      +fetchDailyBalances(userId: String, range: String): Promise<void>
      +generateWeeklyReport(userId: String): Promise<void>
    }
  }

  package "infrastructure" {
    class AnalyticsApiService {
      -httpClient: AxiosInstance
      +getProgressReport(userId: String, type: String): Promise<ProgressReport>
      +getStreaks(userId: String): Promise<Streak[]>
      +getDailyBalances(userId: String, from: String, to: String): Promise<DailyBalance[]>
      +postGenerateReport(userId: String, type: String): Promise<ProgressReport>
    }
  }

  package "presentation.components" {
    class "«Component»\nDashboardView" as DashboardView {
      +loadDashboardData(): void
      +selectDateRange(range: String): void
    }

    class "«Component»\nProgressChartsView" as ProgressChartsView {
      +renderWeightChart(): void
      +renderCalorieChart(): void
      +renderMacroChart(): void
    }

    class "«Component»\nStreakBadgeComponent" as StreakBadgeComponent {
      +streak: Streak
      +getIcon(): String
    }

    class "«Component»\nWeeklyReportCard" as WeeklyReportCard {
      +report: ProgressReport
      +downloadReport(): void
    }
  }
}

' Relationships
AnalyticsStore --> AnalyticsApiService : uses
AnalyticsStore --> ProgressReport : manages "0..1"
AnalyticsStore --> Streak : manages "0..*"
AnalyticsStore --> DailyBalance : manages "0..*"
ProgressReport --> ReportType : has "1"
Streak --> StreakType : has "1"
DashboardView --> AnalyticsStore : uses
ProgressChartsView --> DailyBalance : visualizes "0..*"
StreakBadgeComponent --> Streak : displays "1"
WeeklyReportCard --> ProgressReport : displays "1"

@enduml