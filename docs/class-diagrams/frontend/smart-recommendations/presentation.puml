@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "smart-recommendations/application [stub]" {
  class useSmartRecommendationsStore <<store>>
}

package "subscriptions-billing/presentation [stub]" {
  class FeatureGateComponent <<component>>
}

package "smart-recommendations/presentation/routes" {
  class SmartRecommendationsRoutes <<router>> {
    + path: 'recommendations'
    + name: 'recommendations'
    + component: RecommendationsView
  }
}

package "smart-recommendations/presentation/views" {
  class RecommendationsView <<view>> {
    + activeTab: string
    + unifiedFeed: Array<{type, item, isUnsafe}>
    + filteredCities: Object[]
    + filteredIngredients: IngredientCatalogItem[]
    --
    + handleLogDish(recommendation): void
    + handleRecipeDetail(recipe): void
    + handleLogDishConfirm(payload): void
    + handleLogRecipeConfirm(payload): void
    + handleAddToPantry(): void
    + handleUpdateQuantity(payload): void
    + handleEnableTravel(): Promise
    + handleDisableTravel(): void
    + handleManualConfirm(): void
    + handleAllowLocation(): void
  }
}

package "smart-recommendations/presentation/components" {

  class RecommendationCardComponent <<component>> {
    + props: recommendation, projectedPct, bannerLevel, isUnsafe
    + emits: log
  }

  class RecipeCardComponent <<component>> {
    + props: recipe, pantryIngredientIds, missingLabel, projectedPct, bannerLevel, isUnsafe
    + emits: detail
  }

  class RecipeDetailDialogComponent <<component>> {
    + props: recipe, pantryIngredientIds, ingredientCatalog, visible
    + emits: update:visible, log
  }

  class LogDishDialogComponent <<component>> {
    + props: recommendation, food, visible
    + emits: update:visible, confirm
  }

  class PantryListComponent <<component>> {
    + props: pantryItems, ingredientCatalog, loading
    + emits: remove, update-quantity
  }
}

SmartRecommendationsRoutes ..> RecommendationsView : navigates to >

RecommendationsView *--> RecommendationCardComponent : renders >
RecommendationsView *--> RecipeCardComponent : renders >
RecommendationsView *--> PantryListComponent : renders >
RecommendationsView *--> LogDishDialogComponent : opens >
RecommendationsView *--> RecipeDetailDialogComponent : opens >
RecommendationsView *--> FeatureGateComponent : wraps >

RecommendationsView o--> useSmartRecommendationsStore : uses >

RecommendationCardComponent ..> RecommendationsView : log >
RecipeCardComponent ..> RecommendationsView : detail >
LogDishDialogComponent ..> RecommendationsView : confirm >
RecipeDetailDialogComponent ..> RecommendationsView : log >
PantryListComponent ..> RecommendationsView : remove / update-quantity >

@enduml
