@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "nutrition-tracking/application [stub]" {
  class useNutritionTrackingStore <<store>>
}

package "nutrition-tracking/domain/services [stub]" {
  class FoodRestrictionService <<domain service>>
}

package "nutrition-tracking/presentation/routes" {
  class NutritionTrackingRoutes <<router>> {
    + nutrition-log -> NutritionLogView
    + scan-dish -> ScanDishResultView
    + scan-menu -> ScanMenuResultView
  }
}

package "nutrition-tracking/presentation/views" {

  class NutritionLogView <<view>> {
    + activeTab: string
    + dateLabel: string
    + streakMet: boolean
    --
    + openSearch(meal): void
    + selectFood(food): void
    + confirmAdd(): void
    + removeEntry(logId): void
    + processScanFile(type, file): void
  }

  class ScanDishResultView <<view>> {
    + totals: Object
    + dishBannerLevel: string|null
    --
    + addAllToLog(): void
    + scanAgain(): void
  }

  class ScanMenuResultView <<view>> {
    + menuItemBannerLevel: string|null
    --
    + openAddDialog(food): void
    + confirmAdd(): void
    + scanAgain(): void
  }
}

package "nutrition-tracking/presentation/components" {

  class NutritionLogFormComponent <<component>> {
    + foods: Food[]
    + mealType: string
    + conflictFlags: string[]
    --
    + onSearch(): void
    + selectFood(food): void
    + handleSubmit(): void
  }

  class NutritionLogListComponent <<component>> {
    + logs: NutritionLog[]
    + loading: boolean
    --
    + emit('remove', logId): void
  }
}

NutritionTrackingRoutes ..> NutritionLogView : navigates to >
NutritionTrackingRoutes ..> ScanDishResultView : navigates to >
NutritionTrackingRoutes ..> ScanMenuResultView : navigates to >

NutritionLogView *--> NutritionLogFormComponent : contains >
NutritionLogView *--> NutritionLogListComponent : contains >

NutritionLogView o--> useNutritionTrackingStore : uses >
ScanDishResultView o--> useNutritionTrackingStore : uses >
ScanMenuResultView o--> useNutritionTrackingStore : uses >

NutritionLogView ..> FoodRestrictionService : conflictingFlags >

@enduml
