@startuml
skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "shared/infrastructure [stubs]" {
  class BaseApi <<api>>
  class BaseEndpoint <<api>>
}

package "nutrition-tracking/domain/model [stubs]" {
  class Food <<entity>>
  class NutritionLog <<entity>>
}

package "nutrition-tracking/infrastructure" {

  class NutritionTrackingApi <<api>> {
    - nutritionLogs: BaseEndpoint
    - foods: BaseEndpoint
    --
    + getLogsByUserAndDate(userId, date): Promise
    + getLogById(id): Promise
    + createLog(resource): Promise
    + updateLog(id, resource): Promise
    + deleteLog(id): Promise
    + searchFoods(query, language): Promise
    + getFoodById(id): Promise
    + scanDish(userId, imageBase64): Promise
    + scanMenu(userId, imageBase64): Promise
  }

  class NutritionLogAssembler <<assembler>> {
    + {static} toResource(userId, foodId, grams, mealType, source, date): Object
    + {static} toResourceFromEstimate(userId, foodId, name, macros, mealType, source, date): Object
    + {static} toResourceFromRecipe(userId, recipe, servings, mealType, date): Object
    + {static} toEntityFromResource(resource): NutritionLog|null
    + {static} toEntitiesFromResponse(response): NutritionLog[]
    + {static} toEntityFromResponse(response): NutritionLog|null
  }

  class FoodAssembler <<assembler>> {
    + {static} resolveName(resource, locale): string
    + {static} toEntityFromResource(resource, locale): Food|null
    + {static} toEntitiesFromResponse(response, locale): Food[]
    + {static} toEntityFromResponse(response, locale): Food|null
  }
}

NutritionTrackingApi --|> BaseApi
NutritionTrackingApi *--> BaseEndpoint : endpoints >
NutritionLogAssembler ..> NutritionLog : builds >
FoodAssembler ..> Food : builds >

@enduml
